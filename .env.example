# Paper Fetch Skill configuration
#
# Copy this file to `.env` and fill in the keys you have.
# Blank values are treated as "not configured". Process environment
# variables still override values in this file.

PAPER_FETCH_SKILL_USER_AGENT="paper-fetch-skill/0.2"

# Formula conversion
# Default runtime behavior prefers texmath and falls back to mathml-to-latex.
# Uncomment to force a specific backend:
# MATHML_CONVERTER_BACKEND="texmath"
# TEXMATH_BIN=""
# MATHML_TO_LATEX_NODE_BIN="node"

# Recommended for Crossref polite pool and contactability
CROSSREF_MAILTO=""

# Elsevier official APIs
ELSEVIER_API_KEY=""
ELSEVIER_INSTTOKEN=""
ELSEVIER_AUTHTOKEN=""
ELSEVIER_CLICKTHROUGH_TOKEN=""

# Wiley / Science / PNAS browser workflow
FLARESOLVERR_URL="http://127.0.0.1:8191/v1"
FLARESOLVERR_ENV_FILE=""
FLARESOLVERR_SOURCE_DIR=""
FLARESOLVERR_MIN_INTERVAL_SECONDS=""
FLARESOLVERR_MAX_REQUESTS_PER_HOUR=""
FLARESOLVERR_MAX_REQUESTS_PER_DAY=""
