# Paper Fetch Skill configuration
#
# Copy this file to `.env` and fill in the keys you have.
# Blank values are treated as "not configured". Process environment
# variables still override values in this file.

PAPER_FETCH_SKILL_USER_AGENT="paper-fetch-skill/0.2"

# Formula conversion
# Default runtime behavior prefers texmath and falls back to mathml-to-latex.
# Uncomment to force a specific backend:
# MATHML_CONVERTER_BACKEND="texmath"
# TEXMATH_BIN=""
# MATHML_TO_LATEX_NODE_BIN="node"

# Recommended for Crossref polite pool and contactability
CROSSREF_MAILTO=""

# Springer Nature official APIs
SPRINGER_META_API_KEY=""
SPRINGER_OPENACCESS_API_KEY=""
# Configure these after Springer Nature approves Full Text API access.
# The URL template may use {doi}, {raw_doi}, and {api_key}.
SPRINGER_FULLTEXT_API_KEY=""
SPRINGER_FULLTEXT_URL_TEMPLATE=""
SPRINGER_FULLTEXT_AUTH_HEADER=""
SPRINGER_FULLTEXT_ACCEPT="application/xml"

# Elsevier official APIs
ELSEVIER_API_KEY=""
ELSEVIER_INSTTOKEN=""
ELSEVIER_AUTHTOKEN=""
ELSEVIER_CLICKTHROUGH_TOKEN=""

# Wiley TDM
# The currently documented public Wiley TDM flow returns PDF by default.
WILEY_TDM_URL_TEMPLATE="https://api.wiley.com/onlinelibrary/tdm/v1/articles/{doi}"
WILEY_TDM_TOKEN=""
WILEY_TDM_AUTH_HEADER="Wiley-TDM-Client-Token"
